# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local media and archive drops
IEEE_DSSYWLC'23 Images/
IEEE_DSSYWLC'24 Images/
DSSYWLC ITINERARY.pdf
dssywlc-main/
dssywlc-main.zip

# avoid committing heavy binary media OUTSIDE public/
# (public/ images are allowed so they deploy correctly)
*.mp4
*.mov
*.avi
*.mkv
*.heic

# Test / debug scripts
test-*.cjs
test-*.mjs
